# Runtime profile
APP_ENV=development
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me
DEBUG=1

# Hosts / CORS / CSRF
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,192.168.1.2,academy.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.2:5173,https://academy.yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.2:5173,https://academy.yourdomain.com

# DB (pick one)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/alsyedacademy
# DATABASE_URL=postgres://postgres:postgres@db:5432/alsyedacademy
DATABASE_CONN_MAX_AGE=120
DATABASE_CONN_HEALTH_CHECKS=1
DATABASE_SSL_REQUIRE=0
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_LOCK_TIMEOUT_MS=10000
DATABASE_IDLE_IN_TX_TIMEOUT_MS=30000
DATABASE_CONNECT_TIMEOUT_SECONDS=10

# Optional PgBouncer (Phase 4/5 single-VPS scaling)
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=50
PGBOUNCER_RESERVE_POOL_SIZE=10
PGBOUNCER_RESERVE_POOL_TIMEOUT=5
PGBOUNCER_IGNORE_STARTUP_PARAMETERS=extra_float_digits,options

# Optional PostgreSQL tuning (Phase 4/5, tuned for 8 vCPU / 32 GB)
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=8GB
POSTGRES_EFFECTIVE_CACHE_SIZE=24GB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=1GB
POSTGRES_WAL_BUFFERS=16MB
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_RANDOM_PAGE_COST=1.1
POSTGRES_EFFECTIVE_IO_CONCURRENCY=200

# Redis / cache
REDIS_URL=
CACHE_DEFAULT_TIMEOUT_SECONDS=300
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5
REDIS_SOCKET_TIMEOUT_SECONDS=5
COURSE_LIST_CACHE_TTL_SECONDS=60
COURSE_DETAIL_CACHE_TTL_SECONDS=60
LIVE_CLASS_LIST_CACHE_TTL_SECONDS=30

# Auth / cookies
JWT_COOKIE_SECURE=0
JWT_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
CSRF_COOKIE_HTTPONLY=0
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_AGE=1209600
SESSION_EXPIRE_AT_BROWSER_CLOSE=0
SESSION_SAVE_EVERY_REQUEST=0
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_DOMAIN=
SESSION_ENGINE=

# Security headers / TLS
SECURE_SSL_REDIRECT=0
USE_X_FORWARDED_HOST=1
USE_X_FORWARDED_PORT=1
USE_SECURE_PROXY_SSL_HEADER=1
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURE_CROSS_ORIGIN_RESOURCE_POLICY=same-origin
SECURE_PERMISSIONS_POLICY=accelerometer=(), autoplay=(), camera=(), clipboard-read=(), clipboard-write=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
API_SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=0
SECURE_HSTS_PRELOAD=0
SECURE_REDIRECT_EXEMPT=
SECURE_SSL_HOST=

# Static / media storage
ENABLE_WHITENOISE_STATIC=0
WHITENOISE_MAX_AGE=0
WHITENOISE_ALLOW_ALL_ORIGINS=1
WHITENOISE_KEEP_ONLY_HASHED_FILES=1
RUN_COLLECTSTATIC=1
RUN_MIGRATIONS=1
STARTUP_DB_MAX_ATTEMPTS=20
STARTUP_DB_RETRY_SECONDS=3
USE_GCS_MEDIA_STORAGE=0
GCS_MEDIA_BUCKET_NAME=
GCS_MEDIA_LOCATION=media
GCS_MEDIA_QUERYSTRING_AUTH=0
GCS_MEDIA_CACHE_CONTROL=public,max-age=3600
GCP_PROJECT_ID=
GCS_MEDIA_CUSTOM_DOMAIN=
GOOGLE_APPLICATION_CREDENTIALS=

# Frontend URLs
FRONTEND_URL=http://192.168.1.2:5173
FRONTEND_PUBLIC_ORIGIN=http://192.168.1.2:5173

# Realtime (LiveKit)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_PUBLIC_URL=ws://192.168.1.2:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_MEET_URL=https://meet.livekit.io
REALTIME_DEFAULT_MEETING_CAPACITY=200
REALTIME_DEFAULT_MAX_AUDIENCE=500
REALTIME_JOIN_TOKEN_TTL_SECONDS=3600
REALTIME_SESSION_LIST_CACHE_TTL_SECONDS=5
REALTIME_ENROLLMENT_ACCESS_CACHE_TTL_SECONDS=10
REALTIME_BROADCAST_URL_CACHE_TTL_SECONDS=15
REALTIME_TELEMETRY_ENABLED=1
REALTIME_TELEMETRY_LOG_WINDOW_SECONDS=60
REALTIME_WARN_PARTICIPANT_FALLBACK_SOURCE=1
REALTIME_CAPACITY_WARNING_RATIO=0.8
LIVEKIT_EGRESS_LAYOUT=speaker-dark
LIVEKIT_EGRESS_TWIRP_TIMEOUT_SECONDS=20
LIVEKIT_RECORDING_ENABLED=1
LIVEKIT_RECORDING_FILEPATH_PREFIX=/recordings
LIVEKIT_RECORDING_LOCAL_OUTPUT_ROOT=../infra/recordings
LIVEKIT_RECORDING_OUTPUT_PUBLIC_BASE_URL=

# Broadcast (Owncast)
OWNCAST_BASE_URL=http://localhost:8080
OWNCAST_DEFAULT_STREAM_PATH=/embed/video
OWNCAST_DEFAULT_CHAT_PATH=/embed/chat/readwrite
OWNCAST_RTMP_TARGET=rtmp://owncast:1935/live/replace-with-owncast-stream-key
OWNCAST_STREAM_PUBLIC_BASE_URL=
OWNCAST_CHAT_PUBLIC_BASE_URL=

# Media / CDN
MEDIA_PUBLIC_BASE_URL=

# Integrations
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GOOGLE_CLIENT_ID=

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=your-email@example.com
CONTACT_RECEIVER_EMAIL=your-email@example.com

# App security knobs
FFMPEG_BINARY=ffmpeg
SECURITY_BLOCK_SUSPICIOUS_INPUT=1
SECURITY_MAX_INSPECTION_BODY_BYTES=16384
AUTH_MIN_PASSWORD_LENGTH=12
AUTH_LOGIN_MAX_FAILURES=10
AUTH_LOGIN_LOCKOUT_SECONDS=3600
ACCOUNT_SELF_SERVICE_CREDENTIALS_ENABLED=0
DATA_UPLOAD_MAX_MEMORY_SIZE=2621440
FILE_UPLOAD_MAX_MEMORY_SIZE=2621440
MAX_VIDEO_UPLOAD_BYTES=2147483648
DATA_UPLOAD_MAX_NUMBER_FIELDS=1000
TRUST_X_FORWARDED_FOR=0
TRUSTED_PROXY_COUNT=1

# Production hard-fail controls
ENFORCE_PRODUCTION_REQUIREMENTS=1
ALLOW_SQLITE_IN_PRODUCTION=0
ALLOW_INSECURE_HTTP_ORIGINS=0
SECURE_HSTS_SECONDS_FLOOR=31536000

# Logging
LOG_LEVEL=INFO
DJANGO_SECURITY_LOG_LEVEL=INFO
PERF_MONITORING_ENABLED=1
PERF_DB_QUERY_TRACKING_ENABLED=1
PERF_DB_QUERY_SAMPLE_RATE=1.0
PERF_SLOW_QUERY_MS=120
PERF_DEFAULT_ENDPOINT_BUDGET_MS=800
PERF_WARN_QUERY_COUNT=30
PERF_WARN_QUERY_TIME_MS=300
PERF_LOG_ALL_REQUESTS=0
PERF_RESPONSE_TIME_HEADER_ENABLED=1
PERF_PATH_BUDGETS=/api/realtime/sessions/=650,/api/live-classes/=450,/api/courses/=550,/api/lectures/=650,/api/auth/=500
PERF_LOG_LEVEL=INFO
REALTIME_TELEMETRY_LOG_LEVEL=INFO

# Gunicorn
GUNICORN_BIND=0.0.0.0:8000
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_WORKER_CLASS=gthread
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_WORKER_TMP_DIR=/dev/shm
GUNICORN_LOG_LEVEL=info
GUNICORN_FORWARDED_ALLOW_IPS=*

# Optional container resource limits (Hostinger Phase 2+)
POSTGRES_CPUS=2.0
POSTGRES_MEM_LIMIT=8g
POSTGRES_MEM_RESERVATION=4g
REDIS_CPUS=1.0
REDIS_MEM_LIMIT=2g
REDIS_MEM_RESERVATION=1g
BACKEND_CPUS=2.5
BACKEND_MEM_LIMIT=6g
BACKEND_MEM_RESERVATION=3g
BACKEND_POOL_CPUS=1.5
BACKEND_POOL_MEM_LIMIT=2g
BACKEND_POOL_MEM_RESERVATION=1g
WORKER_CPUS=1.0
WORKER_MEM_LIMIT=1.5g
WORKER_MEM_RESERVATION=768m
TRANSCODER_CPUS=1.2
TRANSCODER_MEM_LIMIT=3g
TRANSCODER_MEM_RESERVATION=1.5g
LIVEKIT_CPUS=2.0
LIVEKIT_MEM_LIMIT=6g
LIVEKIT_MEM_RESERVATION=3g
LIVEKIT_EGRESS_CPUS=1.5
LIVEKIT_EGRESS_MEM_LIMIT=4g
LIVEKIT_EGRESS_MEM_RESERVATION=2g
OWNCAST_CPUS=0.5
OWNCAST_MEM_LIMIT=1g
OWNCAST_MEM_RESERVATION=512m
MEDIA_CPUS=0.75
MEDIA_MEM_LIMIT=1g
MEDIA_MEM_RESERVATION=512m
FRONTEND_CPUS=0.75
FRONTEND_MEM_LIMIT=1g
FRONTEND_MEM_RESERVATION=512m
GATEWAY_CPUS=0.75
GATEWAY_MEM_LIMIT=512m
GATEWAY_MEM_RESERVATION=256m
PGBOUNCER_CPUS=0.75
PGBOUNCER_MEM_LIMIT=512m
PGBOUNCER_MEM_RESERVATION=256m
