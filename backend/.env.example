DJANGO_SECRET_KEY=change-me
DEBUG=1

# Hosts / CORS
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DATABASE_URL=sqlite:///db.sqlite3
DATABASE_CONN_MAX_AGE=120
DATABASE_CONN_HEALTH_CHECKS=1
DATABASE_SSL_REQUIRE=0
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_LOCK_TIMEOUT_MS=10000
DATABASE_IDLE_IN_TX_TIMEOUT_MS=30000

# Auth cookies (dev defaults)
JWT_COOKIE_SECURE=0
JWT_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
CSRF_COOKIE_HTTPONLY=0
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# Security headers / TLS toggles
SECURE_SSL_REDIRECT=0
USE_X_FORWARDED_HOST=1
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=0
SECURE_HSTS_PRELOAD=0

# Frontend URLs
FRONTEND_URL=http://localhost:5173
# Set this in cloud so copied meeting/broadcast links always use your public origin.
FRONTEND_PUBLIC_ORIGIN=

# Integrations
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GOOGLE_CLIENT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
MEDIA_PUBLIC_BASE_URL=

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=no-reply@example.com
CONTACT_RECEIVER_EMAIL=no-reply@example.com

# Realtime defaults
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_PUBLIC_URL=
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_MEET_URL=https://meet.livekit.io
REALTIME_DEFAULT_MEETING_CAPACITY=300
REALTIME_DEFAULT_MAX_AUDIENCE=50000
REALTIME_JOIN_TOKEN_TTL_SECONDS=3600

# Broadcast / Owncast
OWNCAST_BASE_URL=http://localhost:8080
OWNCAST_STREAM_PUBLIC_BASE_URL=
OWNCAST_CHAT_PUBLIC_BASE_URL=
OWNCAST_DEFAULT_STREAM_PATH=/embed/video
OWNCAST_DEFAULT_CHAT_PATH=/embed/chat/readwrite
OWNCAST_RTMP_TARGET=rtmp://owncast:1935/live/replace-with-owncast-stream-key
LIVEKIT_EGRESS_LAYOUT=speaker-dark

# Security hardening knobs
FFMPEG_BINARY=ffmpeg
SECURITY_BLOCK_SUSPICIOUS_INPUT=1
SECURITY_MAX_INSPECTION_BODY_BYTES=16384
AUTH_MIN_PASSWORD_LENGTH=12
AUTH_LOGIN_MAX_FAILURES=6
AUTH_LOGIN_LOCKOUT_SECONDS=900
