# Runtime profile
APP_ENV=production
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=replace-with-a-strong-random-secret-key
DEBUG=0

# Hosts / CORS / CSRF
ALLOWED_HOSTS=api.alsyedinitiative.com,alsyedinitiative.com,www.alsyedinitiative.com
CORS_ALLOWED_ORIGINS=https://alsyedinitiative.com,https://www.alsyedinitiative.com
CSRF_TRUSTED_ORIGINS=https://alsyedinitiative.com,https://www.alsyedinitiative.com

# Database (Cloud SQL Postgres recommended)
DATABASE_URL=postgres://postgres:replace-with-strong-password@/alsyedacademy?host=/cloudsql/clean-feat-430608-i3:replace-region:replace-instance
DATABASE_CONN_MAX_AGE=300
DATABASE_CONN_HEALTH_CHECKS=1
DATABASE_SSL_REQUIRE=1
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_LOCK_TIMEOUT_MS=10000
DATABASE_IDLE_IN_TX_TIMEOUT_MS=30000
DATABASE_CONNECT_TIMEOUT_SECONDS=10

# Redis / cache (Memorystore recommended)
REDIS_URL=redis://10.0.0.10:6379/1
CACHE_DEFAULT_TIMEOUT_SECONDS=300
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5
REDIS_SOCKET_TIMEOUT_SECONDS=5
COURSE_LIST_CACHE_TTL_SECONDS=60
COURSE_DETAIL_CACHE_TTL_SECONDS=60
LIVE_CLASS_LIST_CACHE_TTL_SECONDS=30

# Auth / cookies
JWT_COOKIE_SECURE=1
JWT_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
CSRF_COOKIE_HTTPONLY=1
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_AGE=1209600
SESSION_EXPIRE_AT_BROWSER_CLOSE=0
SESSION_SAVE_EVERY_REQUEST=0
SESSION_COOKIE_DOMAIN=.alsyedinitiative.com
CSRF_COOKIE_DOMAIN=.alsyedinitiative.com
SESSION_ENGINE=django.contrib.sessions.backends.cached_db

# Security headers / TLS
SECURE_SSL_REDIRECT=1
USE_X_FORWARDED_HOST=1
USE_X_FORWARDED_PORT=1
USE_SECURE_PROXY_SSL_HEADER=1
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURE_CROSS_ORIGIN_RESOURCE_POLICY=same-origin
SECURE_PERMISSIONS_POLICY=accelerometer=(), autoplay=(), camera=(), clipboard-read=(), clipboard-write=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
API_SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
SECURE_REDIRECT_EXEMPT=
SECURE_SSL_HOST=

# Static / media storage
ENABLE_WHITENOISE_STATIC=1
WHITENOISE_MAX_AGE=31536000
WHITENOISE_ALLOW_ALL_ORIGINS=1
WHITENOISE_KEEP_ONLY_HASHED_FILES=1
RUN_COLLECTSTATIC=1
RUN_MIGRATIONS=0
STARTUP_DB_MAX_ATTEMPTS=20
STARTUP_DB_RETRY_SECONDS=3
USE_GCS_MEDIA_STORAGE=1
GCS_MEDIA_BUCKET_NAME=replace-with-gcs-media-bucket
GCS_MEDIA_LOCATION=media
GCS_MEDIA_QUERYSTRING_AUTH=0
GCS_MEDIA_CACHE_CONTROL=public,max-age=3600
GCP_PROJECT_ID=clean-feat-430608-i3
GCS_MEDIA_CUSTOM_DOMAIN=
GOOGLE_APPLICATION_CREDENTIALS=

# Frontend URLs
FRONTEND_URL=https://alsyedinitiative.com
FRONTEND_PUBLIC_ORIGIN=https://alsyedinitiative.com

# Realtime (LiveKit)
LIVEKIT_URL=wss://livekit.alsyedinitiative.com
LIVEKIT_PUBLIC_URL=wss://livekit.alsyedinitiative.com
LIVEKIT_API_KEY=replace-livekit-key
LIVEKIT_API_SECRET=replace-livekit-secret
LIVEKIT_MEET_URL=https://meet.livekit.io
REALTIME_DEFAULT_MEETING_CAPACITY=300
REALTIME_DEFAULT_MAX_AUDIENCE=50000
REALTIME_JOIN_TOKEN_TTL_SECONDS=3600
REALTIME_SESSION_LIST_CACHE_TTL_SECONDS=5
REALTIME_TELEMETRY_ENABLED=1
REALTIME_TELEMETRY_LOG_WINDOW_SECONDS=60
REALTIME_WARN_PARTICIPANT_FALLBACK_SOURCE=1
REALTIME_CAPACITY_WARNING_RATIO=0.8
LIVEKIT_EGRESS_LAYOUT=speaker-dark
LIVEKIT_RECORDING_ENABLED=1
LIVEKIT_RECORDING_FILEPATH_PREFIX=/recordings
LIVEKIT_RECORDING_LOCAL_OUTPUT_ROOT=/recordings
LIVEKIT_RECORDING_OUTPUT_PUBLIC_BASE_URL=

# Broadcast (Owncast)
OWNCAST_BASE_URL=https://stream.alsyedinitiative.com
OWNCAST_DEFAULT_STREAM_PATH=/embed/video/
OWNCAST_DEFAULT_CHAT_PATH=/embed/chat/readwrite
OWNCAST_RTMP_TARGET=rtmp://owncast:1935/live/replace-with-owncast-stream-key
OWNCAST_STREAM_PUBLIC_BASE_URL=https://stream.alsyedinitiative.com
OWNCAST_CHAT_PUBLIC_BASE_URL=https://stream.alsyedinitiative.com

# Browser push notifications
WEB_PUSH_ENABLED=0
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:support@alsyedinitiative.com

# Media / CDN
MEDIA_PUBLIC_BASE_URL=

# Integrations
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GOOGLE_CLIENT_ID=

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=admin@alsyedinitiative.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=admin@alsyedinitiative.com
CONTACT_RECEIVER_EMAIL=admin@alsyedinitiative.com

# App security knobs
FFMPEG_BINARY=ffmpeg
SECURITY_BLOCK_SUSPICIOUS_INPUT=1
SECURITY_MAX_INSPECTION_BODY_BYTES=16384
AUTH_MIN_PASSWORD_LENGTH=12
AUTH_LOGIN_MAX_FAILURES=3
AUTH_LOGIN_LOCKOUT_SECONDS=3600
ACCOUNT_SELF_SERVICE_CREDENTIALS_ENABLED=0
DATA_UPLOAD_MAX_MEMORY_SIZE=2621440
FILE_UPLOAD_MAX_MEMORY_SIZE=2621440
MAX_VIDEO_UPLOAD_BYTES=2147483648
DATA_UPLOAD_MAX_NUMBER_FIELDS=1000
TRUST_X_FORWARDED_FOR=1
TRUSTED_PROXY_COUNT=1

# Production hard-fail controls
ENFORCE_PRODUCTION_REQUIREMENTS=1
ALLOW_SQLITE_IN_PRODUCTION=0
ALLOW_INSECURE_HTTP_ORIGINS=0
SECURE_HSTS_SECONDS_FLOOR=31536000

# Logging
LOG_LEVEL=INFO
DJANGO_SECURITY_LOG_LEVEL=INFO
PERF_MONITORING_ENABLED=1
PERF_DB_QUERY_TRACKING_ENABLED=1
PERF_DB_QUERY_SAMPLE_RATE=0.5
PERF_SLOW_QUERY_MS=120
PERF_DEFAULT_ENDPOINT_BUDGET_MS=800
PERF_WARN_QUERY_COUNT=30
PERF_WARN_QUERY_TIME_MS=300
PERF_LOG_ALL_REQUESTS=0
PERF_RESPONSE_TIME_HEADER_ENABLED=0
PERF_PATH_BUDGETS=/api/realtime/sessions/=650,/api/live-classes/=450,/api/courses/=550,/api/lectures/=650,/api/auth/=500
PERF_LOG_LEVEL=INFO
REALTIME_TELEMETRY_LOG_LEVEL=INFO

# Gunicorn
GUNICORN_BIND=0.0.0.0:8000
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_WORKER_CLASS=gthread
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_WORKER_TMP_DIR=/dev/shm
GUNICORN_LOG_LEVEL=info
GUNICORN_FORWARDED_ALLOW_IPS=*
